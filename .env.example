# Public reference deployment. Never commit real credentials.
AIFINPAY_DEMO_MODE=false
AIFINPAY_WALLET_MODE=mainnet
APP_ENV=development
PORT=8787
LOG_LEVEL=info
DATABASE_URL=./data/aifinpay-local.sqlite
SESSION_SECRET=replace-with-at-least-32-random-characters
MCP_PUBLIC_URL=http://localhost:8787/mcp
WIDGET_PUBLIC_URL=http://localhost:8787

# Comma-separated Polygon PoS RPC fallbacks used for read-only balances.
POLYGON_RPC_URLS=https://polygon.drpc.org,https://polygon.publicnode.com

# Optional per-network RPC overrides for read-only balances across all 13
# mainnet networks. Each is comma-separated and falls back to the public
# defaults baked into the app when left blank. Non-EVM networks (Solana, NEAR,
# Aptos, Casper) use their respective JSON-RPC / REST endpoints.
AVALANCHE_RPC_URLS=
ARBITRUM_RPC_URLS=
BNB_RPC_URLS=
BASE_RPC_URLS=
UNICHAIN_RPC_URLS=
OPTIMISM_RPC_URLS=
BOTCHAIN_RPC_URLS=
XRPLEVM_RPC_URLS=
SOLANA_RPC_URLS=
NEAR_RPC_URLS=
APTOS_RPC_URLS=
CASPER_RPC_URLS=

# Casper mainnet RPC nodes are API-key gated. Set CASPER_RPC_URLS to your node
# endpoint (e.g. https://node.mainnet.cspr.cloud/rpc) and CASPER_RPC_AUTH to the
# value sent verbatim as the Authorization header for that node's provider key.
# Left blank, Casper balance reads are unavailable while every other network works.
CASPER_RPC_AUTH=

# Render sets RENDER_EXTERNAL_HOSTNAME automatically; do not add it by hand.

# Private production adapters are not included in this repository.
AIFINPAY_API_BASE_URL=
AIFINPAY_API_KEY=

# Optional production/model integration. The MCP app itself does not require it.
OPENAI_API_KEY=

# Optional explicit demo/testnet adapter placeholders.
POLYGON_RPC_URL=
POLYGON_CHAIN_ID=80002
POLYGON_USDC_ADDRESS=
BLOCK_EXPLORER_BASE_URL=https://amoy.polygonscan.com
