# Demo mode needs no external credentials.
AIFINPAY_DEMO_MODE=true
APP_ENV=development
PORT=8787
LOG_LEVEL=info
DATABASE_URL=./data/aifinpay-demo.sqlite
SESSION_SECRET=replace-with-at-least-32-random-characters
MCP_PUBLIC_URL=http://localhost:8787/mcp
WIDGET_PUBLIC_URL=http://localhost:8787

# Render sets RENDER_EXTERNAL_HOSTNAME automatically; do not add it by hand.

# Existing AiFinPay adapter (not used by deterministic demo mode)
AIFINPAY_API_BASE_URL=
AIFINPAY_API_KEY=

# Optional production/model integration. The MCP app itself does not require it.
OPENAI_API_KEY=

# Polygon Amoy/testnet adapter placeholders
POLYGON_RPC_URL=
POLYGON_CHAIN_ID=80002
POLYGON_USDC_ADDRESS=
BLOCK_EXPLORER_BASE_URL=https://amoy.polygonscan.com
